@startuml SystemArchitecture

skinparam backgroundColor #FFFFFF
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 11
skinparam shadowing false
skinparam roundCorner 12
skinparam nodesep 20
skinparam ranksep 30
skinparam rectangle {
    BorderThickness 2
}

title <b>System Architecture\nBookworms: What is for reading this week?\nFull Project Structure & Request Lifecycle

' ============= PRESENTATION =============
rectangle "**PRESENTATION LAYER**\n<i>Blade Views - Tailwind - Public Assets</i>\n\n**Core:** dashboard, explore, leaderboard, progress, assignments, book\n**Auth:** login, register, forgot-password\n**Admin:** admin/index\n**SchoolAdmin:** banned-books, teachers\n**Teacher:** index, classes/*, user/manage\n**Books:** review   -   **Site:** index\n**Layouts:** layout, login-layout, site-layout\n**Components:** nav-link, form-input, form-error\n**Assets:** Logo, Placeholder, wordcloud, favicon, worm images, profile pics\n**Storage:** covers/, pfp/" as PRES #B3E5FC

' ============= ROUTING / MIDDLEWARE =============
together {
  rectangle "**ROUTING LAYER**\n\nroutes/web.php\nroutes/console.php\n\nMaps requests → controllers,\ngroups by auth & role." as ROUTES #C8E6C9

  rectangle "**MIDDLEWARE**\n<i>Role-Based Access</i>\n\nisAdmin\nIsSchoolAdmin\nisTeacher" as MW #FFF9C4
}

' ============= CONTROLLERS =============
rectangle "**CONTROLLER LAYER**\n<i>Request Handling & Business Logic</i>\n\nAssignment - BookReview - Classroom - Explore - FavouriteBook\nLeaderboard - Manage - Progress - Reading - SchoolAdmin\nSession - Site - Teacher - User - UserManage - (base) Controller" as CTRL #FFE0B2

' ============= MODELS =============
rectangle "**MODEL LAYER**  <i>Eloquent ORM</i>\n\nBook - BookReview - Classroom - Genre - LeaderboardHistory\nPhonic - School - Student - StudentFavouriteBook\nStudentReadingList - StudentWeeklyGoal - User" as MODELS #E1BEE7

' ============= DATABASE =============
rectangle "**DATABASE LAYER**  <i>SQLite: database.sqlite</i>\n\n**Auth:** users, sessions, password_reset_tokens\n**Schools/Classes:** schools, classrooms, classroom_student, archive_classrooms\n**Announcements:** announcements, hidden_announcements\n**Students:** students, student_weekly_goals, student_streaks\n**Reading:** student_reading_lists, student_favourite_books\n**Books:** books, book_reviews, book_review_upvotes, book_student\n**Availability:** book_school_stocks, book_school_ban\n**Pivots:** genres, phonics, book_genre, book_phonic, genre_student\n**Leaderboard:** leaderboard_histories\n**System:** migrations, cache, jobs, failed_jobs" as DB #FFCDD2

' ============= SIDE NODES =============
together {
  rectangle "**CSV IMPORT FILES**\n\nbooks.csv\nbook_genre.csv\nbook_phonic.csv\ngenres.csv\nphonics.csv\nAllStateFunded.csv\nAuthors.csv" as CSV #DCEDC8

  rectangle "**ARTISAN / SEEDERS / FACTORIES**\n\n**Commands:** BackupBooks, FixBookData,\nFixBookGenres, ImportSchools, SyncBooks\n**Seeders:** Database, School, BookBackup,\nBookReview, Synthetic\n**Factories:** Book, Student, User" as CMD #D7CCC8

  rectangle "**TESTING LAYER**\n<i>PHPUnit / Feature Tests</i>\n\nReadingControllerTest\nRouteTest\n\nCovers: recommendations,\nweekly lockout, route\nregistration, guest redirects." as TESTS #CFD8DC
}

' ============= REQUEST FLOW (downwards) =============
PRES   -[#1565C0,bold]down->   ROUTES : **1** HTTP Request
ROUTES -[#2E7D32,bold]down->   MW     : **2** Route Matched
MW     -[#F9A825,bold]down->   CTRL   : **3** Auth Passed
CTRL   -[#E65100,bold]down->   MODELS : **4** Business Logic
MODELS -[#6A1B9A,bold]down->   DB     : **5** Eloquent SQL

' ============= RESPONSE FLOW (dashed) =============
DB     -[#B71C1C,dashed]up-> MODELS : Rows
MODELS -[#6A1B9A,dashed]up-> CTRL   : Models
CTRL   -[#E65100,dashed]up-> PRES   : **6** View / Redirect

' ============= SIDE FLOWS =============
CSV   -[#33691E,dotted]-> CMD : feeds
CMD   -[#5D4037,dotted]-> DB  : seeds / imports
TESTS -[#455A64,dotted]-> CTRL : tests
TESTS -[#455A64,dotted]-> ROUTES : verifies

' ============= LEGEND =============
legend bottom right
  |= Colour |= Layer |
  |<#B3E5FC>     | Presentation |
  |<#C8E6C9>     | Routing |
  |<#FFF9C4>     | Middleware |
  |<#FFE0B2>     | Controllers |
  |<#E1BEE7>     | Models |
  |<#FFCDD2>     | Database |
  |<#DCEDC8>     | CSV Imports |
  |<#D7CCC8>     | Commands/Seeders |
  |<#CFD8DC>     | Tests |
end legend
@enduml